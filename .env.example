# Database Connection URL (PostgreSQL using asyncpg)
# Replace 'YOUR_PASSWORD' with your actual database password, and adjust host/port/db_name if needed.
# Note: The database (e.g. 'whatsapp_sms') must already exist in PostgreSQL.
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/whatsapp_sms

# WhatsApp Client Type Configuration (mock or live)
WHATSAPP_CLIENT_TYPE=mock

META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_BUSINESS_ACCOUNT_ID=
META_TEMPLATE_NAME=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=